model ShippingZone {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  districts String[]
  baseCost  Float
  perItem   Float    @default(0)
  freeAbove Float?
  estDays   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@map("shipping_zone")
}
