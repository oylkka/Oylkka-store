model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  imageUrl      String?
  imagePublicId String?

  parentId String?
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Category[] @relation("SubCategories")

  products Product[]

  featured Boolean @default(false)
  order    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@map("category")
}

model Product {
  id          String @id @default(cuid())
  productName String
  slug        String @unique
  description String

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onUpdate: NoAction)

  tags  String[]
  sku   String   @unique
  brand String?

  price         Decimal @db.Decimal(10, 2)
  discountPrice Decimal? @db.Decimal(10, 2)

  hasVariants Boolean @default(false)
  stock       Int     @default(0)
  lowStockAlert Int     @default(5)

  condition            ProductCondition
  conditionDescription String?

  weight       Float?
  weightUnit   String  @default("kg")
  freeShipping Boolean @default(false)

  dimensionLength Float?
  dimensionWidth  Float?
  dimensionHeight Float?
  dimensionUnit   String @default("cm")

  images ProductImage[]

  variants         ProductVariant[]
  attributeOptions ProductAttributeOption[]

  metaTitle       String?
  metaDescription String?

  status   ProductStatus @default(DRAFT)
  featured Boolean       @default(false)

  shopId String?
  shop   Shop?   @relation("ShopProducts", fields: [shopId], references: [id], onUpdate: NoAction)

  createdBy String
  user      User   @relation(fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: NoAction)

  reviews       Review[]
  reports       ProductReport[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  questions     ProductQuestion[]

  views Int @default(0)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems    OrderItem[]
  conversations Conversation[]

  @@index([categoryId])
  @@index([createdBy])
  @@index([shopId])
  @@index([status])
  @@index([featured])
  @@map("product")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  imageUrl      String
  imagePublicId String
  altText       String?
  order         Int     @default(0)

  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_image")
}

model ProductAttributeOption {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name   String
  values String[]

  @@unique([productId, name])
  @@index([productId])
  @@map("product_attribute_option")
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name String
  sku  String @unique

  price         Decimal @db.Decimal(10, 2)
  discountPrice Decimal? @db.Decimal(10, 2)

  stock Int @default(0)

  attributes Json

  imageUrl      String?
  imagePublicId String?

  cartItems CartItem[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  wishlistItems WishlistItem[]
  orderItems    OrderItem[]

  @@index([productId])
  @@map("product_variant")
}

model ProductQuestion {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  question String

  answer     String?
  answeredAt DateTime?
  answeredBy String?
  answeredByUser User? @relation(name: "answeredByUser", fields: [answeredBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
  @@map("product_question")
}
