// -----------------------------------------------
// category.prisma
// -----------------------------------------------

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  // Cloudinary image
  imageUrl      String?
  imagePublicId String?

  // Self-referential for subcategories
  parentId String?
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Category[] @relation("SubCategories")

  products Product[]

  featured Boolean @default(false)
  order    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@map("category")
}

// -----------------------------------------------
// product.prisma
// -----------------------------------------------

model Product {
  id          String @id @default(cuid())
  productName String
  slug        String @unique
  description String

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onUpdate: NoAction)

  tags  String[]
  sku   String   @unique
  brand String?

  // Pricing
  price         Float
  discountPrice Float? // Store discounted price; derive percent in app

  // Stock — only used when hasVariants is false
  // When hasVariants is true, stock is managed per variant
  hasVariants Boolean @default(false)
  stock       Int     @default(0)

  condition            ProductCondition
  conditionDescription String?

  // Shipping
  weight       Float?
  weightUnit   String  @default("kg")
  freeShipping Boolean @default(false)

  // Dimensions — flat fields instead of composite type
  dimensionLength Float?
  dimensionWidth  Float?
  dimensionHeight Float?
  dimensionUnit   String @default("cm")

  // Main image (required once published)
  imageUrl      String?
  imagePublicId String?

  // Gallery images
  images ProductImage[]

  // Variants and their defining attributes
  variants         ProductVariant[]
  attributeOptions ProductAttributeOption[]

  // SEO
  metaTitle       String?
  metaDescription String?

  // Status and visibility
  status   ProductStatus @default(DRAFT)
  featured Boolean       @default(false)

  // Multi-vendor
  shopId String?
  shop   Shop?   @relation("ShopProducts", fields: [shopId], references: [id], onUpdate: NoAction)

  // Ownership
  createdBy String
  user      User   @relation(fields: [createdBy], references: [id], onUpdate: NoAction)

  // Relationships
  reviews       Review[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  questions     ProductQuestion[]

  // Analytics
  views Int @default(0)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]

  @@index([categoryId])
  @@index([createdBy])
  @@index([shopId])
  @@index([status])
  @@index([featured])
  @@map("product")
}

// Separate table for gallery images
// Main image lives as flat fields on Product itself
model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  imageUrl      String
  imagePublicId String
  altText       String?
  order         Int     @default(0) // for controlling display order

  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_image")
}

// Attribute types defined per product e.g. "Color", "Size"
model ProductAttributeOption {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name   String // e.g. "Color", "Size"
  values String[] // e.g. ["Red", "Blue"], ["S", "M", "L", "XL"]

  @@unique([productId, name])
  @@index([productId])
  @@map("product_attribute_option")
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name String // e.g. "Red / M"
  sku  String @unique

  // Pricing — can override parent product price
  price         Float
  discountPrice Float?

  // Stock always lives here when product hasVariants = true
  stock Int @default(0)

  // Which attribute values this variant represents
  // e.g. { "Color": "Red", "Size": "M" }
  attributes Json

  // Variant-specific image (optional)
  imageUrl      String?
  imagePublicId String?

  cartItems CartItem[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  wishlistItems WishlistItem[]
  orderItems    OrderItem[]

  @@index([productId])
  @@map("product_variant")
}

model ProductQuestion {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  userId   String
  question String

  answer     String?
  answeredAt DateTime?
  answeredBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
  @@map("product_question")
}

// -----------------------------------------------
// enums.prisma (add these to your existing enums file)
// -----------------------------------------------

enum ProductStatus {
  DRAFT
  PUBLISHED
  REJECTED
  ARCHIVED
  OUT_OF_STOCK
}

enum ProductCondition {
  NEW
  USED
  LIKE_NEW
  EXCELLENT
  GOOD
  FAIR
  POOR
  FOR_PARTS
}
